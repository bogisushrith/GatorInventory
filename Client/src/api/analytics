const buildQuery = (days: AnalyticsDays, threshold = 10) => {
    const query = new URLSearchParams();
    query.set("days", String(days));
    query.set("threshold", String(threshold));
    query.set("top_limit", "5");
    query.set("low_stock_limit", "10");
    return query.toString();
};

const parseErrorMessage = async (response: Response, fallback: string) => {
    try {
        const errorPayload = await response.json() as { error_message?: string; message?: string };
        if (errorPayload.error_message && errorPayload.error_message.trim().length > 0) {
            return errorPayload.error_message;
        }
        if (errorPayload.message && errorPayload.message.trim().length > 0) {
            return errorPayload.message;
        }
        return fallback;
    } catch {
        return fallback;
    }
};

const getJson = async <T>(path: string): Promise<T> => {
    const response = await fetch(path, { credentials: "include" });
    if (!response.ok) {
        throw new Error(await parseErrorMessage(response, "Analytics fetch failed"));
    }
    return response.json() as Promise<T>;
};

export const getAnalyticsBundle = async (days: AnalyticsDays, threshold = 10): Promise<AnalyticsBundle> => {
    const query = buildQuery(days, threshold);

    const [summary, revenueTrend, orderTrend, topProducts, lowStockProducts] = await Promise.all([
        getJson<SummaryResponse>(`/api/analytics/summary?${query}`),
        getJson<RevenuePoint[]>(`/api/analytics/revenue-trend?${query}`),
        getJson<OrderPoint[]>(`/api/analytics/order-trend?${query}`),
        getJson<ProductAnalytics[]>(`/api/analytics/top-products?${query}`),
        getJson<LowStockProduct[]>(`/api/analytics/low-stock?${query}`),
    ]);

    return { summary, revenueTrend, orderTrend, topProducts, lowStockProducts };
};
